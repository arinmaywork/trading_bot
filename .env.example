# ============================================================================
# SentiStack V2 — Environment Variables Template
# ============================================================================
# Copy this file to .env and fill in all values marked <REQUIRED>.
# Optional values have sensible defaults shown.
#
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to git — it contains secrets!
# The Dockerfile / docker-compose reads .env automatically.
# ============================================================================


# ────────────────────────────────────────────────────────────────────────────
# ZERODHA KITE CONNECT
# Get these from: https://developers.kite.trade/ → Your App → API Key / Secret
# ────────────────────────────────────────────────────────────────────────────
KITE_API_KEY=<REQUIRED>
KITE_API_SECRET=<REQUIRED>

# Access token is generated fresh each trading day via the /token Telegram command.
# The bot caches it to .kite_token automatically — leave this blank on first run.
KITE_ACCESS_TOKEN=


# ────────────────────────────────────────────────────────────────────────────
# TELEGRAM BOT
# Create a bot via @BotFather → /newbot → copy the token.
# Get your CHAT_ID: send /start to @userinfobot
# ────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=<REQUIRED>
TELEGRAM_CHAT_ID=<REQUIRED>


# ────────────────────────────────────────────────────────────────────────────
# GOOGLE GEMINI (LLM for sentiment analysis)
# Get from: https://aistudio.google.com/app/apikey
# ────────────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=<REQUIRED>


# ────────────────────────────────────────────────────────────────────────────
# OPENWEATHER (alternative data — weather impact on sectors)
# Free tier at: https://openweathermap.org/api
# ────────────────────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=<REQUIRED>


# ────────────────────────────────────────────────────────────────────────────
# EODHD (financial news feed — optional but recommended)
# Free tier at: https://eodhd.com/
# Leave blank to disable news fetching.
# ────────────────────────────────────────────────────────────────────────────
EODHD_API_KEY=


# ────────────────────────────────────────────────────────────────────────────
# FRED (Caldara-Iacoviello GPR Index — optional, data is also public)
# Free key at: https://fred.stlouisfed.org/docs/api/api_key.html
# ────────────────────────────────────────────────────────────────────────────
FRED_API_KEY=


# ────────────────────────────────────────────────────────────────────────────
# REDIS (leave as-is when using docker-compose — bot connects to 'redis' service)
# ────────────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=


# ────────────────────────────────────────────────────────────────────────────
# TRADING PARAMETERS
# ────────────────────────────────────────────────────────────────────────────

# Total capital available for trading (INR).
# For paper trading this is the simulated account size.
TOTAL_CAPITAL=500000

# Set to true for paper trading (simulates fills, no real orders sent to Zerodha).
# Set to false for live trading.
PAPER_TRADE=true

# Minimum trade value in INR. Trades below this size are skipped
# because brokerage would be too large relative to expected P&L.
# Zerodha charges ₹20 flat per order; ₹2000 minimum keeps cost < 2%.
MIN_TRADE_VALUE=2000

# Set to true to use the dynamic ML-driven universe (recommended).
# Set to false to only trade the STATIC_WATCHLIST in config.py.
USE_DYNAMIC_UNIVERSE=true


# ────────────────────────────────────────────────────────────────────────────
# LOGGING
# ────────────────────────────────────────────────────────────────────────────
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
